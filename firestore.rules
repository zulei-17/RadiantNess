rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The Firebase Auth UID.
    //   - displayName: string (required, 1-50 chars) - The user's chosen name.
    //   - streak: int (required, >= 0) - Current daily streak.
    //   - confidenceScore: int (required, 0-100) - Current confidence score.
    //   - lastCheckIn: timestamp (optional) - Last time the user checked in.
    //   - createdAt: timestamp (required) - When the account was created.
    //
    // Collection: /users/{userId}/moods/{moodId}
    // Fields:
    //   - uid: string (required) - The user who logged the mood.
    //   - mood: string (required, enum: great, good, okay, low, bad)
    //   - timestamp: timestamp (required)
    //
    // Collection: /users/{userId}/missions/{missionId}
    // Fields:
    //   - uid: string (required) - The user who accepted the mission.
    //   - title: string (required, 1-100 chars)
    //   - status: string (required, enum: accepted, completed)
    //   - timestamp: timestamp (required)
    //
    // Collection: /community_chat/{messageId}
    // Fields:
    //   - text: string (required, 1-500 chars)
    //   - author: string (required, 1-50 chars)
    //   - color: string (required, hex format)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isNGO() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userRole == 'ngo_business');
    }

    function isSchool() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userRole == 'school');
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'streak', 'confidenceScore', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'displayName', 'streak', 'confidenceScore', 'createdAt', 'lastCheckIn', 'role', 'userRole', 'onboardingData', 'verificationData', 'verified', 'schoolId', 'ngoId', 'needsSupplies', 'photoURL', 'email']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             data.streak is number && data.streak >= 0 &&
             data.confidenceScore is number && data.confidenceScore >= 0 && data.confidenceScore <= 100 &&
             (!('userRole' in data) || data.userRole in ['student', 'parent', 'school', 'ngo_business', 'admin']) &&
             (!('onboardingData' in data) || data.onboardingData is map) &&
             (!('verificationData' in data) || data.verificationData is map) &&
             (!('verified' in data) || data.verified is bool) &&
             (!('needsSupplies' in data) || data.needsSupplies is bool) &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidPrivateDetails(data) {
      return hasRequiredFields(['uid', 'email', 'onboardingData']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.onboardingData is map;
    }

    function isValidMood(data, userId) {
      return hasRequiredFields(['uid', 'mood', 'timestamp']) &&
             hasOnlyAllowedFields(['uid', 'mood', 'timestamp']) &&
             data.uid == userId &&
             data.mood in ['great', 'good', 'okay', 'low', 'bad'] &&
             data.timestamp is timestamp;
    }

    function isValidMission(data, userId) {
      return hasRequiredFields(['uid', 'title', 'status', 'timestamp']) &&
             hasOnlyAllowedFields(['uid', 'title', 'status', 'timestamp']) &&
             data.uid == userId &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             data.status in ['accepted', 'completed'] &&
             data.timestamp is timestamp;
    }

    function isValidChatMessage(data) {
      return hasRequiredFields(['text', 'author', 'color', 'timestamp']) &&
             hasOnlyAllowedFields(['text', 'author', 'color', 'timestamp']) &&
             data.text is string && data.text.size() >= 1 && data.text.size() <= 500 &&
             data.author is string && data.author.size() >= 1 && data.author.size() <= 50 &&
             data.color is string && data.color.matches("^#[0-9a-fA-F]{6}$") &&
             data.timestamp is timestamp;
    }

    function isValidRequest(data) {
      return hasRequiredFields(['requesterUid', 'productType', 'quantity', 'status', 'timestamp']) &&
             hasOnlyAllowedFields(['requesterUid', 'schoolId', 'productType', 'quantity', 'status', 'location', 'rejectionReason', 'timestamp']) &&
             data.requesterUid is string &&
             data.productType is string &&
             data.quantity is number && data.quantity > 0 &&
             data.status in ['pending', 'approved', 'rejected', 'shipped', 'delivered'] &&
             (!('location' in data) || data.location is map) &&
             (!('rejectionReason' in data) || data.rejectionReason is string) &&
             data.timestamp is timestamp;
    }

    function isValidDonation(data) {
      return hasRequiredFields(['donorUid', 'amount', 'donorType', 'productType', 'status', 'timestamp']) &&
             hasOnlyAllowedFields(['donorUid', 'ngoId', 'amount', 'donorType', 'productType', 'schoolName', 'brand', 'urgency', 'status', 'timestamp']) &&
             data.donorUid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.donorType in ['school', 'individual'] &&
             data.productType is string &&
             data.status in ['approved', 'shipped'] &&
             (!('urgency' in data) || data.urgency in ['within a week', 'within this month', 'within the next 2 months']) &&
             data.timestamp is timestamp;
    }

    function isValidAnnouncement(data) {
      return hasRequiredFields(['schoolUid', 'type', 'title', 'content', 'timestamp']) &&
             hasOnlyAllowedFields(['schoolUid', 'schoolName', 'type', 'title', 'content', 'timestamp']) &&
             data.schoolUid == request.auth.uid &&
             data.type in ['supplies', 'workshop', 'session', 'general'] &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 2000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    ((!('role' in resource.data) && !('role' in request.resource.data)) || 
                     (resource.data.get('role', 'user') == request.resource.data.get('role', 'user')) || 
                     isAdmin());

      match /moods/{moodId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMood(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidMood(request.resource.data, userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /missions/{missionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMission(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidMission(request.resource.data, userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /student_private_details/{userId} {
      allow read: if isAdmin();
      allow create: if isOwner(userId) && isValidPrivateDetails(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /community_chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChatMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSchool() || isAdmin());
      allow update: if isAuthenticated() && (isNGO() || isAdmin()) && isValidRequest(request.resource.data);
      allow delete: if isAdmin();
    }

    match /donations/{donationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isNGO() || isAdmin()) && isValidDonation(request.resource.data);
      allow update: if isAuthenticated() && (isNGO() || isAdmin()) && isValidDonation(request.resource.data);
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSchool() || isAdmin()) && isValidAnnouncement(request.resource.data);
      allow update: if isAuthenticated() && (isSchool() || isAdmin()) && isValidAnnouncement(request.resource.data);
      allow delete: if isAuthenticated() && (isSchool() || isAdmin()) && request.auth.uid == resource.data.schoolUid;
    }
  }
}
